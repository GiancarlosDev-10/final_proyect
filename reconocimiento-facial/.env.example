# URL pública de tu app en Vercel (sin barra al final)
API_BASE_URL=https://colegio-juan-velasco.vercel.app

# Debe ser EXACTAMENTE el mismo valor que pusiste en Vercel como ASISTENCIA_API_SECRET
ASISTENCIA_API_SECRET=

# Distancia máxima para aceptar una coincidencia (más bajo = más estricto)
TOLERANCIA=0.5
# Margen mínimo de distancia entre el mejor y el segundo mejor candidato
MARGEN_MINIMO=0.05
# Votación temporal: ventana de frames y votos mínimos para confirmar
VENTANA_FRAMES=4
VOTOS_MINIMOS=3

INTERVALO_ENROLAMIENTO_SEG=30
INTERVALO_REFRESCO_ENCODINGS_SEG=60
COOLDOWN_TRAS_MARCAR_SEG=120

PUERTO=5000

# Origen permitido para CORS (la URL de tu app en Vercel). Usa "*" solo para pruebas.
ORIGEN_PERMITIDO=https://colegio-juan-velasco.vercel.app
